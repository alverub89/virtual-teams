# Banco. Em produção na Netlify, NETLIFY_DATABASE_URL é injetada pelo Netlify DB
# (Neon provisionado automaticamente). Localmente, deixe vazio para usar o
# PGlite embarcado (modo demo), ou aponte para um Neon próprio via DATABASE_URL.
NETLIFY_DATABASE_URL=
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Provedor de IA. Sem AI_BASE_URL, roda o mock de demonstração.
# Para o Omni AI Gateway (repo omni-ai-gateway): AI_GATEWAY_KIND=omni,
# AI_BASE_URL = URL do gateway, OMNI_PRODUCT_KEY = token omni_prod_...
AI_GATEWAY_KIND=omni
AI_BASE_URL=https://alverub-ai-api.netlify.app
OMNI_PRODUCT_KEY=
AI_GATEWAY_PROVIDER=openai
AI_MODELS_JSON={"avancado":"gpt-4.1","intermediario":"gpt-4o","leve":"gpt-4o-mini"}

# Login GitHub (OAuth) + GitHub App (tools de repositório)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=

# Email (convites) — Resend. Vazio = não envia; o convite ainda gera link manual.
# Em produção, defina RESEND_API_KEY (re_...) nas env vars do site na Netlify.
RESEND_API_KEY=
# URL pública do app (usada nos links de convite). Em produção a Netlify já
# injeta URL; APP_URL sobrescreve se quiser um domínio fixo.
APP_URL=

# Sessão
SESSION_JWT_SECRET=troque-por-um-segredo-forte

# Integrações
IUCLICK_API_URL=
IUCLICK_TOKEN=
ATLAN_API_URL=
ATLAN_TOKEN=
SERVICENOW_URL=
SERVICENOW_USER=
SERVICENOW_PWD=
CATALOGO_API_URL=
CATALOGO_TOKEN=

# Observabilidade
SENTRY_DSN=

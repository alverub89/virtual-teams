# Banco (Neon) — runtime usa o endpoint POOLED; migrations usam o direto
DATABASE_URL=postgres://user:pwd@ep-xxx-pooler.region.aws.neon.tech/ai_workspace?sslmode=require
DATABASE_URL_UNPOOLED=postgres://user:pwd@ep-xxx.region.aws.neon.tech/ai_workspace?sslmode=require

# Provedor de IA próprio (contrato OpenAI-compatible)
AI_BASE_URL=https://ia.interna.example.com/v1
AI_API_KEY=
AI_MODELS_JSON={"avancado":"modelo-a","intermediario":"modelo-b","leve":"modelo-c"}

# Login GitHub (OAuth) + GitHub App (tools de repositório)

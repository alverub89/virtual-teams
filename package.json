{
  "name": "ai-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "AI Workspace — plataforma AI-First de produto (Netlify + Neon + provedor de IA próprio)",
  "type": "module",
  "scripts": {
    "dev": "netlify dev",
    "build": "pnpm --filter web build",
    "typecheck": "tsc -p tsconfig.json --noEmit && pnpm --filter web typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.16",
    "jose": "^5.9.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@netlify/functions": "^2.8.2",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2"
  }
}
